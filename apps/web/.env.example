# Copy to `.env.local` and tweak for your needs.

# Public base URL of the Strapi backend (used by server components and the
# browser when building image URLs).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Read/write Strapi API token (full access). Server-only — never exposed to the
# browser. Create one in Strapi: Settings → API Tokens → "Full access".
STRAPI_API_TOKEN=

# Simple password protecting the /admin area. Used to set the admin_session
# cookie. Choose a strong value in production.
ADMIN_SECRET=changeme

# Optional: set to "standalone" for Docker builds.
# NEXT_OUTPUT=standalone
