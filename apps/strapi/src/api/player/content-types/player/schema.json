{
  "kind": "collectionType",
  "collectionName": "players",
  "info": {
    "singularName": "player",
    "pluralName": "players",
    "displayName": "Player",
    "description": "A registered tournament participant"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "age": {
      "type": "integer",
      "min": 0
    },
    "flatNumber": {
      "type": "string"
    },
    "mobile": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "players"
    },
    "groups": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::group.group",
      "mappedBy": "players"
    },
    "registeredAt": {
      "type": "datetime"
    }
  }
}
